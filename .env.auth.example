APP_REQUIRE_AUTH=true
APP_LOGIN_URL=https://the360insights.ai/login
APP_POST_LOGIN_URL=https://the360insights.ai/
APP_USERNAME=replace-with-secure-username
APP_PASSWORD=replace-with-secure-password

# Optional selector overrides when the login form is custom.
APP_USERNAME_SELECTOR=
APP_PASSWORD_SELECTOR=
APP_SUBMIT_SELECTOR=

# Optional authenticated-shell markers.
# Comma-separated Playwright/CSS selectors that confirm a successful app entry.
APP_SUCCESS_SELECTORS=aside,nav,[role="navigation"],[class*="sidebar"],text=Dashboard

# Limit authenticated discovery breadth.
APP_DISCOVERY_MAX_PAGES=8
